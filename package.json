{
  "name": "logger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.1",
  "bin": {
    "logger": "./bin/logger"
  },
  "scripts": {
    "dev": "bun run src/main.tsx",
    "build": "bunx tsc -p tsconfig.json",
    "start": "bun run dist/main.js",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test tests/*.test.ts",
    "test:e2e": "bun run build && bun test tests/e2e/*.test.ts",
    "repo:dump": "find . \\( -path './node_modules' -o -path './dist' \\) -prune -o -type f -print | sort | while read f; do printf '\\n===== %s =====\\n' \"$f\"; cat \"$f\"; done > REPO_DUMP.txt",
    "compile:exe": "bun build --compile ./src/main.tsx --outfile ./bin/logger"
  },
  "dependencies": {
    "clipboardy": "^4.0.0",
    "commander": "^13.1.0",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "react-devtools-core": "file:./vendor/react-devtools-core"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.18",
    "typescript": "^5.8.3"
  }
}
